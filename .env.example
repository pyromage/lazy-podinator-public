# Anthropic API for Claude AI script generation
export ANTHROPIC_API_KEY="your-anthropic-api-key"
export CLAUDE_MODEL="claude-sonnet-4-6"

# Google Cloud Project settings
export PROJECT_ID="your-gcp-project-id"
export BUCKET_NAME="your-podcast-bucket-name"

# Cloud Run / Cloud Build settings
export REGION="your-gcp-region"
export SERVICE_NAME="your-cloud-run-service-name"

# Failure email notifications (Gmail API)
# Run scripts/setup_gmail.py once to authorize and upload the OAuth token to GCS
export NOTIFY_EMAIL="your-gmail@gmail.com"
export GMAIL_CREDENTIALS_FILE="gmail_credentials.json"
